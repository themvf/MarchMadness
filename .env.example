# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/march_madness?sslmode=require

# The Odds API
ODDS_API_KEY=your_odds_api_key_here

# LineStar session cookie (for automated projection/ownership fetch)
# Copy from DevTools → Application → Cookies → www.linestarapp.com → .DOTNETNUKE
# Refresh after it expires (typically 30 days)
DNN_COOKIE=your_dotnetnuke_cookie_value_here
